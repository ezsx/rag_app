SEMANTIC_MCP_REPO_ROOT=/target_repo
SEMANTIC_MCP_QDRANT_URL=http://host.docker.internal:6333
SEMANTIC_MCP_TEI_URL=http://host.docker.internal:8082
SEMANTIC_MCP_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
SEMANTIC_MCP_EMBEDDING_BACKEND=tei_http
SEMANTIC_MCP_PROFILE_NAME=gpu_qwen3
SEMANTIC_MCP_INCLUDE_GLOBS=auto
SEMANTIC_MCP_EXCLUDE_GLOBS=.git/**,.venv/**,venv/**,**/__pycache__/**,node_modules/**,**/*.png,**/*.jpg,**/*.jpeg,**/*.gif,**/*.webp,**/*.ico,**/*.svg,**/*.zip,**/*.gz,**/*.tar,**/*.7z,**/*.pdf,**/*.db,**/*.sqlite,**/.env*,**/*.pem,**/*.key,**/*.npy,**/*.npz,datasets/_*
SEMANTIC_MCP_TRANSPORT=http
SEMANTIC_MCP_HTTP_HOST=0.0.0.0
SEMANTIC_MCP_HTTP_PORT=8011
SEMANTIC_MCP_AUTO_INDEX_ON_START=1
SEMANTIC_MCP_WATCH_ENABLED=1
SEMANTIC_MCP_WATCH_DEBOUNCE_SEC=3
SEMANTIC_MCP_LOG_LEVEL=info
SEMANTIC_MCP_COLLECTION_PREFIX=repo_semantic
SEMANTIC_MCP_INDEX_SCHEMA_VERSION=1
SEMANTIC_MCP_MAX_CHUNK_CHARS=1000
SEMANTIC_MCP_EMBED_BATCH_DOCS=32
SEMANTIC_MCP_EMBED_BATCH_CHARS=18000
SEMANTIC_MCP_QUERY_TEMPLATE=Instruct: Retrieve relevant code and documentation snippets for repository search.\nQuery: {query}
